@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold">Sistema de Gestión</h1>
    <h3 class="text-muted">Control de Miembros del Gimnasio</h3>
    <hr class="w-50 mx-auto my-4" />
